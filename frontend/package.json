{
  "name": "finance-sentry",
  "version": "0.7.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --code-coverage --browsers=ChromeHeadless",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "e2e": "ng e2e",
    "prepare": "husky",
    "build:lib": "ng build @dsdevq-common/ui",
    "build:lib:watch": "ng build @dsdevq-common/ui --watch",
    "storybook": "ng run \"@dsdevq-common/ui:storybook\"",
    "build-storybook": "ng run \"@dsdevq-common/ui:build-storybook\"",
    "test:lib": "ng test @dsdevq-common/ui",
    "test:vrt": "playwright test --config=projects/dsdevq-common/ui/playwright.config.ts"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{html,scss,css,json}": [
      "prettier --write"
    ]
  },
  "private": true,
  "workspaces": [
    "projects/dsdevq-common/*"
  ],
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-browser-dynamic": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@ngrx/signals": "^21.1.0",
    "@types/chroma-js": "^3.1.2",
    "chart.js": "^4.5.1",
    "chroma-js": "^3.2.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "^0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.7",
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular-devkit/core": "^21.2.7",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@angular/language-service": "^21.2.5",
    "@playwright/test": "1.58.2",
    "@smarttools/eslint-plugin-rxjs": "^1.0.22",
    "@storybook/angular": "^10.3.5",
    "@types/google.accounts": "^0.0.14",
    "@types/node": "^25.5.0",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "21.3.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "ng-packagr": "^21.2.0",
    "playwright-ng-schematics": "^21.0.9",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "storybook": "^10.3.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.1.2"
  }
}
