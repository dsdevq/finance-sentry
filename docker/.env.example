PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
JWT_SECRET=change-this-in-production
ENCRYPTION_MASTER_KEY=change-this-in-production
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# IBKR Client Portal Gateway (via IBeam sidecar). Optional — leave blank to skip IBKR.
# Use paper-trading credentials in dev. IBeam re-authenticates every ~24h automatically.
IBKR_ACCOUNT=your_ibkr_paper_username
IBKR_PASSWORD=your_ibkr_paper_password
